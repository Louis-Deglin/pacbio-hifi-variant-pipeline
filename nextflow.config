// Minimum Nextflow version: the workflow output{} block requires Nextflow >= 24.04.
manifest {
    name            = 'find_specific_mutation'
    description      = 'PacBio HiFi targeted variant-discovery pipeline with VEP annotation and optional methylation profiling and SV calling'
    nextflowVersion  = '>=24.04.0'
}

params {
    // CSV samplesheet (columns: sample,bam,chromosome,interval)
    input = null
    reference = null

    // Output directory (also drives the workflow output{} block, see outputDir below)
    outdir = 'Results'

    // Run name: when set, results land under <outdir>/<run_name>/ (one folder per run).
    // Null = backward-compatible behavior (results directly under <outdir>/).
    run_name = null

    // VEP annotation source: provide EITHER vep_cache OR vep_gff (mutually exclusive)
    vep_cache = null
    vep_gff   = null

    // VEP species & assembly (defaults: cattle / ARS-UCD2.0)
    vep_species  = 'bos_taurus'
    vep_assembly = 'ARS-UCD2.0'

    // Skip the global MultiQC report
    skip_multiqc = false

    // Methylation profiling (pb-CpG-tools) - opt-in, uses the HiPhase haplotagged BAM
    run_methylation = false

    // Structural variant calling (sawfish) - opt-in, uses the aligned BAM
    run_sv = false

    // Extra args, transmis aux outils
    align_args      = ''
    deepvariant_args = ''
    vep_args        = ''

    // Heavy-process resources (CallVariants / CallSV only). Fixed per-tier values,
    // chosen in run.sh (Normal / High / Very High / Custom) and passed on the CLI.
    // The "Normal" tier equals these defaults. cpus is coerced to int and memory to
    // MemoryUnit at the withName blocks below so CLI overrides work. Time is NOT
    // tunable (kept at the per-process baseline).
    callvariants_cpus   = 36
    callvariants_memory = '120.GB'
    callsv_cpus         = 36
    callsv_memory       = '160.GB'


    slurm_account = null
}

// =============================================================================
// Execution profiles (composable: pick one engine + one site, e.g.
//   nextflow run ... -profile singularity,hpc2n
// Engine profiles configure the container runtime; site profiles configure the
// executor / scheduler. They are orthogonal so any engine x site combination works.
// Self-contained: no dependency on the remote nf-core/configs repository.
// =============================================================================
profiles {

    // ---- Container engines ----
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        // Portable cache location: read NXF_SINGULARITY_CACHEDIR if exported
        // (recommended on shared clusters), else a project-local folder.
        singularity.cacheDir   = System.getenv('NXF_SINGULARITY_CACHEDIR') ?: "${projectDir}/.singularity_cache"
    }

    docker {
        docker.enabled = true
    }

    conda {
        conda.enabled = true
    }

    // ---- Compute sites ----
    // Default profile (auto-applied when -profile is omitted): run locally.
    standard {
        process.executor = 'local'
    }

    local {
        process.executor = 'local'
    }

    hpc2n {
        process.executor       = 'slurm'
        // Pass '-A <account>' only when --slurm_account is set; otherwise let SLURM
        // use the user's default account.
        process.clusterOptions = params.slurm_account ? "-A ${params.slurm_account}" : ''
    }
}

process {
    withName: 'DetectAndStandardize' {
         cpus = 5
         memory = 25.GB
         time = 10.min
     }

    // Align is fixed (light enough not to need the resource tiers).
    withName: 'Align' {
        cpus = 25
        memory = 50.GB
        time = 2.h
        ext.args = params.align_args
    }

    // CallVariants (DeepVariant): cpus/memory driven by the run.sh resource tier
    // (Normal/High/Very High/Custom). Time stays fixed.
    withName: 'CallVariants' {
         cpus = params.callvariants_cpus as int
         memory = params.callvariants_memory as nextflow.util.MemoryUnit
         time = 8.h
         ext.args = params.deepvariant_args
     }

    withName: 'HiPhase' {
        cpus = 16
        memory = 30.GB
        time = 1.h
    }

    withName: 'ExtractIntervals' {
        cpus = 5
        memory = 10.GB
        time = 10.min
    }

    withName: 'MethylationProfiling' {
        cpus = 16
        memory = 30.GB
        time = 30.min
    }

    withName: 'SliceMethylation' {
        cpus = 5
        memory = 10.GB
        time = 10.min
    }

    // CallSV (sawfish): cpus/memory driven by the run.sh resource tier. Time fixed.
    withName: 'CallSV' {
        cpus = params.callsv_cpus as int
        memory = params.callsv_memory as nextflow.util.MemoryUnit
        time = 2.h
    }

    withName: 'SliceSV' {
        cpus = 5
        memory = 10.GB
        time = 10.min
    }

    withName: 'AnnotateSVWithVEP' {
        cpus = 5
        memory = 10.GB
        time = 10.min
        ext.args = params.vep_args
    }

    withName: 'AnnotateWithVEP' {
        cpus = 5
        memory = 10.GB
        time = 10.min
        ext.args = params.vep_args
    }

    withName: 'IntervalReport' {
        cpus = 5
        memory = 10.GB
        time = 10.min
    }

    withName: 'RunReport' {
        cpus = 5
        memory = 10.GB
        time = 10.min
    }

    withName: 'SamtoolsStats' {
        cpus = 5
        memory = 10.GB
        time = 30.min
    }

    withName: 'BcftoolsStats' {
        cpus = 5
        memory = 10.GB
        time = 30.min
    }

    // Aliased process (BcftoolsStats as BcftoolsStatsSV): needs its own selector since
    // withName matches the alias name, not the original process name.
    withName: 'BcftoolsStatsSV' {
        cpus = 5
        memory = 10.GB
        time = 10.min
    }

    withName: 'MultiQC' {
        cpus = 5
        memory = 10.GB
        time = 10.min
    }
}

// Base directory for the workflow output{} block (per-sample subdirs are added there).
// Kept in sync with params.outdir so `run.sh --outdir` keeps working. When --run_name
// is set, every run is grouped under <outdir>/<run_name>/.
outputDir = params.run_name ? "${params.outdir}/${params.run_name}" : params.outdir
